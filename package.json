{
  "name": "agent-bridge",
  "version": "1.0.0",
  "description": "Local WebSocket bridge for routing Zhipin Claw Agent requests to private OpenClaw and QwenPaw backends.",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "desktop": "npm run build && electron .",
    "package:mac": "npm run build && electron-builder --mac dmg",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.zhipinclaw.agentbridge",
    "productName": "Zhipin Claw Agent Bridge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "README.md",
      ".env.example"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}

# Agent Bridge local configuration
# Copy this file to .env for CLI/dev use. The packaged desktop app can also be
# configured from its local web UI.

# Cloud tunnel endpoint from Zhipin Claw.
CLOUD_WS_URL=ws://localhost:3000/node-tunnel?userId=replace-with-user-id
CLOUD_AUTH_TOKEN=replace-with-node-token

# OpenClaw backend. Requires OpenClaw to expose POST /v1/chat/completions.
OPENCLAW_ENABLED=true
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=replace-with-openclaw-token
OPENCLAW_AGENT_ID=main

# QwenPaw backend.
QWENPAW_ENABLED=false
QWENPAW_BASE_URL=http://127.0.0.1:8088
QWENPAW_TOKEN=
QWENPAW_AGENT_ID=default

# Remote AgentID -> local agent/backend mapping.
# Format: remoteAgentId:localAgentId:backend,remote2:local2:qwenpaw
BRIDGE_MAPPINGS=agent_xxx:main:openclaw

# Bridge runtime options.
DEFAULT_BACKEND=openclaw
BRIDGE_PORT=9876
AUTO_RECONNECT=true
RECONNECT_INTERVAL=5000
MAX_RECONNECT_ATTEMPTS=0
HEARTBEAT_INTERVAL=10000
LOG_LEVEL=info
